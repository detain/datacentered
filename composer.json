{
	"name": "detain/datacentered",
	"description": "Service providing Asynchronous communication and updates to the host servers vps related stuff.",
	"type": "project",
	"keywords": [
		"server",
		"administration",
		"vps"
	],
	"minimum-stability": "dev",
	"license": "LGPL-2.1-or-later",
	"authors": [
		{
			"name": "Joe Huss",
			"email": "detain@interserver.net"
		}
	],
	"require": {
		"php": ">=8.2",
		"ext-curl": "*",
		"corneltek/cliframework": "^3.0",
		"roave/security-advisories": "dev-latest",
		"react/child-process": "^0.6.7@stable",
		"react/event-loop": "^1.6.0@stable",
		"react/http": "^1.11.0@stable",
		"react/mysql": "^0.6.0@stable",
		"guzzlehttp/guzzle": "^7.13.1@stable",
		"danielstjules/php-pretty-datetime": "dev-master",
		"influxdata/influxdb-client-php": "dev-master",
		"cache/memcached-adapter": "^1.2.0",
		"workerman/channel": "dev-master",
		"workerman/coroutine": "^1.1.5",
		"workerman/gatewayclient": "dev-master",
		"workerman/gateway-worker" : "dev-master",
		"workerman/globaldata": "dev-master",
		"workerman/mysql": "dev-master",
		"workerman/workerman": "^5.2.2@stable"
	},
	"require-dev": {
		"react/promise": "^3.0",
		"phpunit/phpunit": "^12.5",
		"vlucas/phpdotenv": "dev-master",
		"satooshi/php-coveralls": "^0.6.1",
		"codacy/coverage": "dev-master"
	},
	"suggest": {
		"codeclimate/php-test-reporter": "dev-master",
		"ext-event": "*",
		"ext-ev": "*"
	},
	"config": {
		"minimum-stability": "dev",
		"optimize-autoloader": true,
		"sort-packages": true,
		"allow-plugins": {
			"php-http/discovery": true
		}
	},
	"autoload": {
		"psr-4": {
			"MyAdmin\\VpsHost\\": "src/"
		}
	}
}
